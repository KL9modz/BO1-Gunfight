			forecolor		1 1 1 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r1_cnt" ) > 3 ) && ( dvarInt( "ui_gf_r1_alive" ) <= 3 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}

