		// ── Kill popup (menu-rendered, 0 client hudelems) ────────────────────
		// "Elimination" / "Assist" center-screen, fading via ui_gf_popup_alpha (pushed + animated by
		// gf_showScorePopup). 0 client hudelems → works at any player count, unlike the old lazily-
		// created client hudelem that fell past the per-client DRAWN render cap once the lobby grew.
		// ui_gf_popup_type: 2 = elim, 1 = assist. Gated by ui_gf_popup_show.

		// Elimination
		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			-100 -60 200 20 HORIZONTAL_ALIGN_CENTER VERTICAL_ALIGN_CENTER
			exp				text( locString( "@GF_POPUP_ELIMINATION" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.5
			textalign		ITEM_ALIGN_MIDDLE_CENTER
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		1 1 0.5 1
			exp				forecolor A( dvarFloat( "ui_gf_popup_alpha" ) )
			visible			when( dvarInt( "ui_gf_popup_show" ) && ( dvarInt( "ui_gf_popup_type" ) == 2 ) )
			decoration
		}

		// Assist
		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			-100 -60 200 20 HORIZONTAL_ALIGN_CENTER VERTICAL_ALIGN_CENTER
			exp				text( locString( "@GF_POPUP_ASSIST" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.5
			textalign		ITEM_ALIGN_MIDDLE_CENTER
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		1 1 0.5 1
			exp				forecolor A( dvarFloat( "ui_gf_popup_alpha" ) )
			visible			when( dvarInt( "ui_gf_popup_show" ) && ( dvarInt( "ui_gf_popup_type" ) == 1 ) )
			decoration
		}
	}

	// ═══════════════════════════════════════════════════════════════════════════
	// Pregame lobby HUD — SEPARATE menuDef, deliberately NOT gated on BIT_HUD_VISIBLE.
	// The engine clears hud_visible=0 entering the intermission state (the lobby cam uses
	// spawnIntermission), which would blank the whole gf_health menuDef above — so the lobby
	// chrome lives here, gated ONLY by !BIT_IN_KILLCAM !BIT_UI_ACTIVE at the menu level and by
	// ui_gf_lobby_show per item. Do NOT add !BIT_SCOREBOARD_OPEN — the intermission scoreboard
	// sets that bit and would hide us. GSC (gf_lobbyCamPut) pushes ui_gf_lobby_show/welcome/map/
	// status per client. This band wraps the stock intermission scoreboard (which is the roster);
	// left rules + right server/ads columns are added once this band is confirmed to render.
	// ═══════════════════════════════════════════════════════════════════════════
	menuDef
	{
		name			"gf_lobby_hud"
		rect			0 0 640 480 HORIZONTAL_ALIGN_FULLSCREEN VERTICAL_ALIGN_FULLSCREEN
		fullScreen		0
		visible			1
		visibilityBits	bits( !BIT_IN_KILLCAM )

		// -- TOP-CENTER branding: eyebrow / wordmark / map (centered, clear of the top-left minimap) --
		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			-160 4 320 10 HORIZONTAL_ALIGN_CENTER VERTICAL_ALIGN_TOP
			exp				text( dvarString( "ui_gf_lobby_eyebrow" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.2
			textalign		ITEM_ALIGN_TOP_CENTER
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		1 0.42 0.1 1
			visible			when( dvarInt( "ui_gf_lobby_show" ) )
			decoration
		}
		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			-160 16 320 26 HORIZONTAL_ALIGN_CENTER VERTICAL_ALIGN_TOP
			exp				text( dvarString( "ui_gf_lobby_title" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.55
			textalign		ITEM_ALIGN_TOP_CENTER
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		1 1 1 1
			visible			when( dvarInt( "ui_gf_lobby_show" ) )
			decoration
		}
		// Cycling weapon icons flanking the GUNFIGHT title — same dvar-driven material idiom as the
		// loadout overview / panel skulls. GSC (gf_lobbyIconCycler) walks ui_gf_lobby_icon through the
		// arsenal; ui_gf_lobby_icon_on flips 1 only after the typewriter finishes the title line, so the
		// pair pops in when the wordmark settles. Natural (white) tint. The LEFT icon uses a NEGATIVE
		// rect width — the engine's mirrored draw (stock precedent: hud_rps.menu draws its border art
		// with -38/-220 widths) — so the two guns face each other.
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			-118 15 -56 28 HORIZONTAL_ALIGN_CENTER VERTICAL_ALIGN_TOP
			exp				material( dvarString( "ui_gf_lobby_icon" ) );
			forecolor		1 1 1 0.95
			visible			when( dvarInt( "ui_gf_lobby_show" ) && dvarInt( "ui_gf_lobby_icon_on" ) )
			decoration
		}
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			62 15 56 28 HORIZONTAL_ALIGN_CENTER VERTICAL_ALIGN_TOP
			exp				material( dvarString( "ui_gf_lobby_icon" ) );
			forecolor		1 1 1 0.95
			visible			when( dvarInt( "ui_gf_lobby_show" ) && dvarInt( "ui_gf_lobby_icon_on" ) )
			decoration
		}
		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			-160 50 320 12 HORIZONTAL_ALIGN_CENTER VERTICAL_ALIGN_TOP
			exp				text( dvarString( "ui_gf_lobby_map" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.3
			textalign		ITEM_ALIGN_TOP_CENTER
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		0.66 0.69 0.72 1
			visible			when( dvarInt( "ui_gf_lobby_show" ) )
			decoration
		}

