// Gunfight health HUD menu overlay.
// Tiny HP labels are menu text so they do not consume script HUD elems.

#include "ui/menudef.h"
#include "ui_mp/hud_gametypes.inc"

{
	menuDef
	{
		name			"gf_health_hp_numbers"
		rect			0 0 640 480 HORIZONTAL_ALIGN_FULLSCREEN VERTICAL_ALIGN_FULLSCREEN
		fullScreen		0
		visible			1
		visibilityBits	bits( BIT_HUD_VISIBLE !BIT_IN_KILLCAM !BIT_UI_ACTIVE HUD_VISIBILITY )

		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			0 -50 30 10 HORIZONTAL_ALIGN_USER_LEFT VERTICAL_ALIGN_CENTER
			exp				rect X( dvarInt( "ui_gf_health_hp0_x" ) )
			exp				text( dvarString( "ui_gf_health_hp0" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.20
			textalign		ITEM_ALIGN_MIDDLE_LEFT
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		0.42 0.68 0.46 0.85
			visible			when( dvarInt( "ui_gf_health_hp_visible" ) && dvarInt( "ui_gf_health_hp0_show" ) )
			decoration
		}

		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			0 -32 30 10 HORIZONTAL_ALIGN_USER_LEFT VERTICAL_ALIGN_CENTER
			exp				rect X( dvarInt( "ui_gf_health_hp1_x" ) )
			exp				text( dvarString( "ui_gf_health_hp1" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.20
			textalign		ITEM_ALIGN_MIDDLE_LEFT
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		0.73 0.29 0.19 0.85
			visible			when( dvarInt( "ui_gf_health_hp_visible" ) && dvarInt( "ui_gf_health_hp1_show" ) )
			decoration
		}

		// -- Team panel border (menu-rendered) -- fades via ui_gf_hp_alpha --------
		// LEFT vertical cap + top/middle/bottom rules at ui_gf_panel_x/y (gf_pushPanelChrome).
		// Gated by ui_gf_panel_show; alpha cross-fades with the client-hudelem panel via
		// ui_gf_hp_alpha (gf_revealHealthPanel). SHADER+white so forecolor-A drives the fade.
		itemDef
		{
			rect			0 0 142 0.5 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) - 1 )
			style			WINDOW_STYLE_SHADER
			background		"white"
			forecolor		0 0 0 1
			exp				forecolor A( 0.5 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) )
			decoration
		}
		itemDef
		{
			rect			0 0 142 0.5 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 20 )
			style			WINDOW_STYLE_SHADER
			background		"white"
			forecolor		0 0 0 1
			exp				forecolor A( 0.5 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) )
			decoration
		}
		itemDef
		{
			rect			0 0 142 0.5 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 39 )
			style			WINDOW_STYLE_SHADER
			background		"white"
			forecolor		0 0 0 1
			exp				forecolor A( 0.5 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) )
			decoration
		}
		itemDef
		{
			rect			0 0 0.5 40 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) )
			style			WINDOW_STYLE_SHADER
			background		"white"
			forecolor		0 0 0 1
			exp				forecolor A( 0.5 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) )
			decoration
		}

		// ══ Team health panel rows (fully menu-rendered — 0 client hudelems) ══
		// bg fade + EITHER 8 skulls (ui_gf_hp_mode 0) OR 2 "Alive: N" readouts (mode 1, both rows together) + 2 bars + 2 numbers, anchored to ui_gf_panel_x/y (gf_pushPanelChrome),
		// faded by ui_gf_hp_alpha (gf_revealHealthPanel). Per-row data: ui_gf_rN_hp / _fw / _cnt /
		// _alive (gf_pushHealthRow). Row 0 = friendly (green), row 1 = enemy (red). Skulls: an alive
		// (team-colour) item + a dead (white) item per slot, gated by alive/cnt (forecolor R/G/B can't
		// be exp-driven, so two items per slot). Gated by ui_gf_panel_show.

		// soft dark background fade (first = drawn behind the rows)
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 320 48 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) - 128 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) - 5 )
			exp				material( dvarString( "ui_gf_fade_mat" ) );
			forecolor		0 0 0 1
			exp				forecolor A( 0.55 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) )
			decoration
		}

		// ─── Row 0 (friendly, green) ───
		// bar background
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			rect			0 0 40 2 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 85 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 15 )
			background		"white"
			forecolor		0 0 0 1
			exp				forecolor A( 0.45 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) )
			decoration
		}
		// bar fill (width = ui_gf_r0_fw px)
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			rect			0 0 1 2 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 85 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 15 )
			exp				rect W( dvarInt( "ui_gf_r0_fw" ) )
			background		"white"
			forecolor		0.42 0.68 0.46 1
			exp				forecolor A( 0.9 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) )
			decoration
		}
		// HP number
		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			0 0 60 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 85 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 2 )
			exp				text( dvarString( "ui_gf_r0_hp" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.3
			textalign		ITEM_ALIGN_MIDDLE_LEFT
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		1 1 1 1
			exp				forecolor A( dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) )
			decoration
		}
		// skull slot 0 — alive (green)
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 10 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 30 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 6 )
			exp				material( dvarString( "ui_gf_skull_mat" ) );
			forecolor		0.42 0.68 0.46 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r0_alive" ) > 0 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}
		// skull slot 0 — dead (white)
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 10 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 30 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 6 )
			exp				material( dvarString( "ui_gf_skull_mat" ) );
			forecolor		1 1 1 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r0_cnt" ) > 0 ) && ( dvarInt( "ui_gf_r0_alive" ) <= 0 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}
		// skull slot 1 — alive
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 10 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 43 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 6 )
			exp				material( dvarString( "ui_gf_skull_mat" ) );
			forecolor		0.42 0.68 0.46 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r0_alive" ) > 1 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}
		// skull slot 1 — dead
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 10 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 43 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 6 )
			exp				material( dvarString( "ui_gf_skull_mat" ) );
			forecolor		1 1 1 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r0_cnt" ) > 1 ) && ( dvarInt( "ui_gf_r0_alive" ) <= 1 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}
		// skull slot 2 — alive
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 10 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 56 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 6 )
			exp				material( dvarString( "ui_gf_skull_mat" ) );
			forecolor		0.42 0.68 0.46 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r0_alive" ) > 2 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}
		// skull slot 2 — dead
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 10 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 56 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 6 )
			exp				material( dvarString( "ui_gf_skull_mat" ) );
			forecolor		1 1 1 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r0_cnt" ) > 2 ) && ( dvarInt( "ui_gf_r0_alive" ) <= 2 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}
		// skull slot 3 — alive
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 10 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 69 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 6 )
			exp				material( dvarString( "ui_gf_skull_mat" ) );
			forecolor		0.42 0.68 0.46 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r0_alive" ) > 3 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}
		// skull slot 3 — dead
		itemDef
		{
			style			WINDOW_STYLE_SHADER
			type			ITEM_TYPE_IMAGE
			rect			0 0 10 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 69 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 6 )
			exp				material( dvarString( "ui_gf_skull_mat" ) );
			forecolor		1 1 1 1
			exp				forecolor A( 0.95 * dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_r0_cnt" ) > 3 ) && ( dvarInt( "ui_gf_r0_alive" ) <= 3 ) && ( dvarInt( "ui_gf_hp_mode" ) == 0 ) )
			decoration
		}

		// "Alive: N" readout — shown INSTEAD of the 4-skull cluster when the shared ui_gf_hp_mode
		// is 1 (either team > 4, so BOTH rows switch together — never one skulls / one readout).
		// Small mode / <=4v4 stays in mode 0, so the skull cluster above is byte-identical.
		// Centered on the vacated skull footprint.
		itemDef
		{
			type			ITEM_TYPE_TEXT
			rect			0 0 50 10 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
			exp				rect X( dvarInt( "ui_gf_panel_x" ) + 30 )
			exp				rect Y( dvarInt( "ui_gf_panel_y" ) + 5 )
			exp				text( dvarString( "ui_gf_r0_alivecount" ) )
			textfont		UI_FONT_NORMAL
			textscale		0.3
			textalign		ITEM_ALIGN_MIDDLE_CENTER
			textstyle		ITEM_TEXTSTYLE_SHADOWEDMORE
			forecolor		0.42 0.68 0.46 1
			exp				forecolor A( dvarFloat( "ui_gf_hp_alpha" ) )
			visible			when( dvarInt( "ui_gf_panel_show" ) && ( dvarInt( "ui_gf_hp_mode" ) == 1 ) )
			decoration
		}

