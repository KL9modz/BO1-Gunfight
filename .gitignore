# Build output
mod.ff
tools/dist/

# Runtime/log output
*.log
*.log.*
missingasset.csv
__converter/
demos/
imgui.ini
main/
players/
plutonium/
zone/

# Claude Code — local permissions (machine-specific paths)
.claude/settings.json
.claude/settings.local.json

# Join notifier — real config carries the secret ntfy topic (acts like a password)
tools/notify/config.json

# Box-local "mute from the activity surfaces" list (status_service + join-notify read it).
# Holds player GUIDs — account identifiers, and this repo is public. Template is .example
tools/ignore.local.json

# RCON panel — real rcon_password store (per-profile). Never commit; template is .example
tools/rcon/secrets.local.json

# RCON panel — box-local UI state (the FAVORITES pinboard). Lives with the PANEL, not the browser,
# so the VPS panel shows one pinboard over RDP and over the SSH tunnel alike. Regenerated on demand.
tools/rcon/prefs.local.json

# RCON panel — learned per-server cache of dvars the game server rejects as "Unknown command"
# (so the connect-sweep stops bare-sending them). Machine/server-specific; regenerated on demand.
tools/rcon/.dvarcache.json

# RCON panel — geo lookup cache (player IP -> country/city, from ip-api.com). PII: it maps real
# player IPs to locations, so it stays on the box and never enters git or a web root. Only the
# 2-letter country code derived from it is ever published. Regenerated on demand.
tools/rcon/.geocache.json

# Watchdog — box-local alert-state (down/recovered transitions), regenerated on demand
tools/vps_services/watchdog_state.json

# Watchdog — self-expiring maintenance marker written by deploy.ps1 to mute alerts during a
# planned restart; box-local, always transient
tools/vps_services/watchdog_maintenance.json

# Loadout editor — rolling backup written next to the edited .gsc on each save
*.editorbak

# Local-only reference/server files
dedicated.cfg
dedicated_sp.cfg
# Server cfgs: block any real/live cfg (carries rcon_password) but allow sanitized templates.
server/*.cfg
!server/*.cfg.example
gsc resources/
raw/
tools/ff_extract/
